generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  adherent
  membre_bureau
  sympathisant
  administrateur
}

enum ProfileStatus {
  pending
  approved
  rejected
}

enum ProjectStatus {
  en_cours
  cloture
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  profile   Profile?

  @@map("users")
}

model Profile {
  id                      String        @id @default(uuid())
  userId                  String        @unique @map("user_id")
  user                    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName               String?       @map("first_name")
  lastName                String?       @map("last_name")
  fullName                String?       @map("full_name")
  email                   String?
  avatarUrl               String?       @map("avatar_url")
  city                    String?
  country                 String?
  personalDescription     String?       @map("personal_description")
  role                    UserRole?
  status                  ProfileStatus @default(pending)
  isEmailVerified         Boolean       @default(false) @map("is_email_verified")
  skills                  String[]
  associationContribution String?       @map("association_contribution")
  invitedById             String?       @map("invited_by")
  invitedBy               Profile?      @relation("InvitedBy", fields: [invitedById], references: [id])
  invitations             Profile[]     @relation("InvitedBy")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  eventParticipants EventParticipant[]
  projectMembers    ProjectMember[]
  personalProjects  PersonalProject[]

  @@map("profiles")
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  status      ProjectStatus @default(en_cours)
  startDate   DateTime?     @map("start_date")
  endDate     DateTime?     @map("end_date")
  createdAt   DateTime?     @default(now()) @map("created_at")
  updatedAt   DateTime?     @updatedAt @map("updated_at")
  members     ProjectMember[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  profileId String   @map("profile_id")
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime? @default(now()) @map("created_at")

  @@map("project_members")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  location    String?
  startDate   DateTime @map("start_date")
  endDate     DateTime? @map("end_date")
  type        String?
  createdBy   String?  @map("created_by")
  createdAt   DateTime? @default(now()) @map("created_at")
  participants EventParticipant[]

  @@map("events")
}

model EventParticipant {
  id        String  @id @default(uuid())
  eventId   String  @map("event_id")
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  profileId String  @map("profile_id")
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  status    String?
  createdAt DateTime? @default(now()) @map("created_at")

  @@map("event_participants")
}

model Article {
  id        String   @id @default(uuid())
  title     String
  summary   String
  content   String
  published Boolean  @default(false)
  date      DateTime?
  userId    String?  @map("user_id")
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("articles")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  type        String
  description String?
  color       String?
  createdAt   DateTime? @default(now()) @map("created_at")

  @@map("categories")
}

model Notification {
  id                String   @id @default(uuid())
  userId            String?  @map("user_id")
  title             String
  message           String
  type              String
  isRead            Boolean  @default(false) @map("is_read")
  relatedEntityId   String?  @map("related_entity_id")
  relatedEntityType String?  @map("related_entity_type")
  createdAt         DateTime? @default(now()) @map("created_at")

  @@map("notifications")
}

model PersonalProject {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  profile     Profile? @relation(fields: [userId], references: [id], onDelete: SetNull)
  title       String?
  description String?
  status      String?
  deadline    DateTime?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("personal_projects")
}
