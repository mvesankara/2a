generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  adherent
  membre_bureau
  sympathisant
  administrateur
}

enum ProfileStatus {
  pending
  approved
  rejected
}

enum ProjectStatus {
  en_cours
  en_revue
  cloture
}

enum TaskStatus {
  todo
  in_progress
  done
  review
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  password            String
  createdAt           DateTime             @default(now()) @map("created_at")
  profile             Profile?
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

model Profile {
  id                      String        @id @default(uuid())
  userId                  String        @unique @map("user_id")
  user                    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName               String?       @map("first_name")
  lastName                String?       @map("last_name")
  fullName                String?       @map("full_name")
  email                   String?
  avatarUrl               String?       @map("avatar_url")
  city                    String?
  country                 String?
  personalDescription     String?       @map("personal_description")
  dateOfBirth             DateTime?     @map("date_of_birth")
  gender                  String?
  address                 String?
  phone                   String?
  profession              String?
  organization            String?
  motivation              String?
  howDidYouHear           String?       @map("how_did_you_hear")
  interests               String[]
  membershipType          String?       @map("membership_type")
  membershipExpiresAt     DateTime?     @map("membership_expires_at")
  idDocumentUrl           String?       @map("id_document_url")
  role                    UserRole?
  status                  ProfileStatus @default(pending)
  isEmailVerified         Boolean       @default(false) @map("is_email_verified")
  skills                  String[]
  associationContribution String?       @map("association_contribution")
  invitedById             String?       @map("invited_by")
  invitedBy               Profile?      @relation("InvitedBy", fields: [invitedById], references: [id])
  invitations             Profile[]     @relation("InvitedBy")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  eventParticipants EventParticipant[]
  projectMembers    ProjectMember[]
  personalProjects  PersonalProject[]
  createdProjects   Project[]         @relation("ProjectCreator")
  tasks             Task[]

  @@map("profiles")
}

model Project {
  id               String        @id @default(uuid())
  name             String
  shortDescription String?       @map("short_description")
  description      String?
  category         String?
  imageUrl         String?       @map("image_url")
  isPublished      Boolean       @default(false) @map("is_published")
  status           ProjectStatus @default(en_cours)
  progress         Int           @default(0)
  city                String?
  country             String?       @default("Gabon")
  problemStatement    String?       @map("problem_statement")
  estimatedDuration   String?       @map("estimated_duration")
  objectives          String?
  plannedActivities   String?       @map("planned_activities")
  targetBeneficiaries String?       @map("target_beneficiaries")
  successIndicators   String?       @map("success_indicators")
  budget              Float?
  budgetSources       String?       @map("budget_sources")
  humanResources      String?       @map("human_resources")
  materialResources   String?       @map("material_resources")
  priority            String?
  budgetSpent         Float?        @map("budget_spent")
  createdByProfileId  String?       @map("created_by_profile_id")
  createdByProfile    Profile?      @relation("ProjectCreator", fields: [createdByProfileId], references: [id], onDelete: SetNull)
  startDate           DateTime?     @map("start_date")
  endDate             DateTime?     @map("end_date")
  createdAt           DateTime?     @default(now()) @map("created_at")
  updatedAt           DateTime?     @updatedAt @map("updated_at")
  members             ProjectMember[]
  tasks               Task[]
  activities          ProjectActivity[]
  indicators          ProjectIndicator[]
  documents           Document[]

  @@map("projects")
}

model ProjectActivity {
  id        String    @id @default(uuid())
  projectId String    @map("project_id")
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  date      DateTime?
  status    String    @default("a_venir")
  order     Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("project_activities")
}

model ProjectIndicator {
  id        String  @id @default(uuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String
  current   Float   @default(0)
  target    Float
  unit      String?
  order     Int     @default(0)

  @@map("project_indicators")
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("subscribers")
}

model Stat {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  label     String
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("stats")
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(todo)
  dueDate     DateTime?  @map("due_date")
  priority    String?    @default("normal")
  progress    Int        @default(0)
  isBlocked   Boolean    @default(false)  @map("is_blocked")
  profileId   String?    @map("profile_id")
  profile     Profile?   @relation(fields: [profileId], references: [id], onDelete: SetNull)
  projectId   String?    @map("project_id")
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("tasks")
}

model ProjectMember {
  id        String    @id @default(uuid())
  projectId String    @map("project_id")
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  profileId String    @map("profile_id")
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  role      String?   @default("Membre actif")
  createdAt DateTime? @default(now()) @map("created_at")

  @@map("project_members")
}

model Document {
  id        String   @id @default(uuid())
  name      String
  fileType  String   @default("PDF") @map("file_type")
  url       String?
  sizeBytes Int?     @map("size_bytes")
  isPublic  Boolean  @default(true) @map("is_public")
  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("documents")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  location    String?
  startDate   DateTime @map("start_date")
  endDate     DateTime? @map("end_date")
  type        String?
  createdBy   String?  @map("created_by")
  createdAt   DateTime? @default(now()) @map("created_at")
  participants EventParticipant[]

  @@map("events")
}

model EventParticipant {
  id        String  @id @default(uuid())
  eventId   String  @map("event_id")
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  profileId String  @map("profile_id")
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  status    String?
  createdAt DateTime? @default(now()) @map("created_at")

  @@map("event_participants")
}

model Article {
  id        String   @id @default(uuid())
  title     String
  summary   String
  content   String
  published Boolean  @default(false)
  date      DateTime?
  userId    String?  @map("user_id")
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("articles")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  type        String
  description String?
  color       String?
  createdAt   DateTime? @default(now()) @map("created_at")

  @@map("categories")
}

model Notification {
  id                String   @id @default(uuid())
  userId            String?  @map("user_id")
  title             String
  message           String
  type              String
  isRead            Boolean  @default(false) @map("is_read")
  relatedEntityId   String?  @map("related_entity_id")
  relatedEntityType String?  @map("related_entity_type")
  createdAt         DateTime? @default(now()) @map("created_at")

  @@map("notifications")
}

model PersonalProject {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  profile     Profile? @relation(fields: [userId], references: [id], onDelete: SetNull)
  title       String?
  description String?
  status      String?
  deadline    DateTime?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("personal_projects")
}
